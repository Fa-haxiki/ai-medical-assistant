# 通义千问 API Key（阿里云 DashScope）
# 可选：ALIBABA_API_KEY 与 DASHSCOPE_API_KEY 二选一即可
# 若无 .env 文件，本文件也会被自动加载
DASHSCOPE_API_KEY=sk-047b8adf22a94b80a0eb8a42a67ade4e
# ALIBABA_API_KEY=your_alibaba_api_key_here

# 服务端口与地址
PORT=8000
HOST=localhost

# 前端地址，用于 CORS
CORS_ALLOW_ORIGINS=http://localhost:3000

# Chroma 向量库地址（不设置则禁用 RAG，仅使用大模型回答）
# 示例：先启动 Chroma 容器: docker run -p 8010:8000 chromadb/chroma
CHROMA_URL=http://localhost:8010
# 或分别指定
# CHROMA_HOST=localhost
# 集合名称（可选）
# CHROMA_COLLECTION=medical-knowledge

# 知识库 Markdown 文件路径（可选，默认会查找 knowledge/full1.md 或 ../backend/full1.md）
# KNOWLEDGE_PATH=./knowledge/full1.md

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=19952024lls
MYSQL_DATABASE=medical_assistant
