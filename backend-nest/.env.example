# 通义千问 / DashScope API Key（必须填一个）
# 在真实环境中请填写自己的密钥，并且不要提交到 Git 仓库
# DASHSCOPE_API_KEY=your_dashscope_api_key_here
# ALIBABA_API_KEY=your_alibaba_api_key_here

# 服务端口与地址
PORT=8000
HOST=localhost

# 允许的前端地址（CORS）
# 如有多个域名可用逗号分隔，例如：http://localhost:3000,https://your.domain
CORS_ALLOW_ORIGINS=http://localhost:3000

# Chroma 向量库地址（不设置则禁用 RAG，仅使用大模型回答）
# 示例：先启动 Chroma 容器: docker run -p 8010:8000 chromadb/chroma
# CHROMA_URL=http://localhost:8010
# 可选：指定集合名称
# CHROMA_COLLECTION=medical-knowledge

# RAG 重排（可选，默认开启）
RERANK_ENABLED=true
RERANK_PROVIDER=dashscope
RERANK_MODEL=qwen3-vl-rerank
# 粗召回数量（向量检索）
RERANK_TOP_K=20
# 重排保留数量
RERANK_TOP_N=5
# 重排超时毫秒
RERANK_TIMEOUT_MS=1200
# 拼接到 prompt 的上下文最大字符数
RAG_CONTEXT_MAX_CHARS=7000
# ZIP 批量上传内 PDF 文件数上限
MAX_ZIP_FILE_COUNT=200
# ZIP 解压后总大小上限（MB）
MAX_ZIP_UNCOMPRESSED_MB=200
# ZIP 批量任务超时（毫秒）
ZIP_JOB_TIMEOUT_MS=300000

# 知识库 Markdown 文件路径（可选）
# KNOWLEDGE_PATH=./knowledge/full1.md

# MySQL 会话与知识库元数据持久化（可选，如果不配置 MYSQL_DATABASE 则使用内存会话）
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=medical_assistant

# 会话清理策略（可选）
# 会话超过多少天未活跃则删除（默认 30）
CONVERSATION_INACTIVE_DAYS=30
# 单会话最多保留消息条数（默认 200）
MAX_MESSAGES_PER_CONVERSATION=200

# 参数与限流（可选）
# 单条消息最大字符数（默认 10000）
MAX_MESSAGE_LENGTH=10000
# chat_history 最大条数（默认 50）
MAX_CHAT_HISTORY_LENGTH=50
# 多模态图片 base64 最大 MB（默认 5）
MAX_IMAGE_SIZE_MB=5
# 知识库上传文件最大 MB（默认 100）
MAX_UPLOAD_FILE_SIZE_MB=100
# 限流时间窗口（秒，默认 60）
THROTTLE_TTL_SECONDS=60
# 每 IP 时间窗口内最大请求数（默认 120）
THROTTLE_LIMIT=120
# 同一 IP 允许的并发对话/流式请求数（默认 3）
MAX_CONCURRENT_CHAT_PER_IP=3

